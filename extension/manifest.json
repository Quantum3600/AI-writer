{
    "manifest_version": 3,
    "name": "AI Writer",
    "version": "1.0",
    "description": "AI Writer",
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "audioCapture"
    ],
    "host_permissions": [
        "http://localhost:8080/*"
    ]
}