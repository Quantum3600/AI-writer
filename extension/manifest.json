{
    "manifest_version": 3,
    "name": "AI Writer",
    "version": "1.0",
    "description": "AI Writer",
    "action": {
        "default_title": "Click to open AI Writer",
        "default_icon": "icon.png"
    },
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "sidePanel"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-script.js"
            ],
            "run_at": "document_idle",
            "all_frames": true
        }
    ],
    "host_permissions": [
        "http://localhost:8080/*",
        "http://127.0.0.1:8080/*",
        "<all_urls>"
    ]
}